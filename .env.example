# Vercel Postgres
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Admin auth
ADMIN_PASSWORD=change-me
JWT_SECRET=change-me-random-32-chars

# VPS connection
VPS_API_URL=https://your-vps-ip:8443
VPS_API_TOKEN=change-me-random-token
VPS_IP=0.0.0.0

# Reality protocol (from Xray config)
REALITY_SNI=dl.google.com
REALITY_PUBLIC_KEY=your-public-key
REALITY_SHORT_ID=your-short-id

# Cron auth
CRON_SECRET=change-me-random-secret

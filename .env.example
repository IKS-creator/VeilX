# Vercel Postgres
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Admin auth
ADMIN_PASSWORD=change-me
JWT_SECRET=change-me-random-32-chars

# Multi-server config (JSON array)
# Each server: id, label, apiUrl, apiToken, ip, port, sni, pbk, sid
VPS_SERVERS='[{"id":"stockholm","label":"Швеция","apiUrl":"https://70.34.204.16:8443","apiToken":"token1","ip":"70.34.204.16","port":443,"sni":"dl.google.com","pbk":"public-key-1","sid":"short-id-1"},{"id":"russia","label":"Россия","apiUrl":"https://85.239.62.204:8443","apiToken":"token2","ip":"85.239.62.204","port":2053,"sni":"dl.google.com","pbk":"public-key-2","sid":"short-id-2"}]'

# Legacy single-server fallback (used if VPS_SERVERS is not set)
# VPS_API_URL=https://your-vps-ip:8443
# VPS_API_TOKEN=change-me-random-token
# VPS_IP=0.0.0.0
# REALITY_SNI=dl.google.com
# REALITY_PUBLIC_KEY=your-public-key
# REALITY_SHORT_ID=your-short-id

# Cron auth
CRON_SECRET=change-me-random-secret
